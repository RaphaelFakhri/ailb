---
// Offering cards render transparent-PNG subjects that "pop" off their
// colored backgrounds — same compositional technique as the reference
// hero (colored block + cutout subject + label chip at bottom).
// Images go through <Image /> so Astro emits a 2x webp (tiny — the
// PNG originals are 500KB–1.1MB each; webp at the actual render
// dimensions is typically 20–80KB).
import { Image } from "astro:assets";
import sidekickImg from "../assets/offerings/hero-things.webp";
import squadImg from "../assets/offerings/hero-services.webp";
import flashImg from "../assets/offerings/hero-gigs.webp";
import bountyImg from "../assets/offerings/hero-gov.webp";

type Card = {
  label: string;
  tagline: string;
  href: string;
  hint?: string; // tiny extra line (e.g. the /gov/ "requires login" lock)
  image: ImageMetadata;
  // Flat color of the top "squircle" block (not a gradient — reference uses solid pastels)
  blockBg: string;
  imgW: number;
  imgAspect: number;     // width / height of the image wrapper
  imgTopOffset: number;  // negative = wrapper extends above block top edge
  // People use cover+top so only head/shoulders are visible (waist cropped),
  // grounded with the wrapper bottom at the colored block's top edge.
  // Objects use contain+bottom so the full shape is visible inside the card.
  imgFit: "cover" | "contain";
  imgPos: "top" | "bottom" | "center";
  // Optional drop-shadow. Used for hard-edged objects (e.g. the watch)
  // so they lift off the pastel block instead of sitting flat on it.
  imgShadow?: string;
  // Clip the image to the block's rounded top corners — needed when the
  // source has a non-transparent (white) background that would otherwise
  // poke past the block's curve at the corners.
  imgClipTop?: boolean;
};

const cards: Card[] = [
  {
    label: "Product Marketplace",
    tagline: "Cars, phones, furniture — listed and priced by the agent.",
    href: "#things",
    image: sidekickImg,
    blockBg: "#deede0",  // soft green
    imgW: 188,
    imgAspect: 1.22,      // matches trimmed cutout (436×358) — wrapper fills 188×154
    imgTopOffset: -34,    // bottom flush with block; subject pops 34px above
    imgFit: "contain",
    imgPos: "bottom",
  },
  {
    label: "Services Marketplace",
    tagline: "Electricians, tutors, beauty — real calendars, fixed quotes.",
    href: "#services",
    image: squadImg,
    blockBg: "#e4ecf2",  // soft blue
    imgW: 199,
    imgAspect: 1.29,      // wrapper matches trio cutout — image fills 199×154
    imgTopOffset: -34,    // bottom flush with block; trio pops 34px above
    imgFit: "contain",
    imgPos: "bottom",
  },
  {
    label: "One-time Services",
    tagline: "Moving, repairs, urgent jobs — one quote, in writing.",
    href: "#gigs",
    image: flashImg,
    blockBg: "#f2ebe1",  // soft taupe
    imgW: 110,
    imgAspect: 0.78,      // stopwatch natural aspect
    imgTopOffset: -32,
    imgFit: "contain",
    imgPos: "bottom",
    imgShadow: "drop-shadow(0 10px 18px rgba(0,0,0,0.25)) drop-shadow(0 4px 6px rgba(0,0,0,0.15))",
  },
  {
    label: "Government Services",
    tagline: "Visa files, ikhraj qaid, mécanique — go once, with everything.",
    href: "#government",
    hint: "🔒 requires login",
    image: bountyImg,
    blockBg: "#f2e6ec",  // soft pink
    imgW: 180,
    imgAspect: 1.90,      // landscape book
    imgTopOffset: 4,
    imgFit: "contain",
    imgPos: "bottom",
  },
];
---

<section
  class="hero-sec relative text-white md:h-[640px]"
  aria-label="ailb pillars"
>
  <!--
    Dimensions pulled from the reference and applied verbatim:
     - desktop height: 524px (mobile: auto)
     - top padding: 80px
     - content gap: 60px mobile / 70px desktop
     - headline block max-width: 700px
     - card row max-width: 918px
     - card colored block: 120px tall, compact (not portrait aspect)
  -->

  <!--
    Giant wordmark watermark behind the cards. Technique pulled from the
    reference:
      - opacity: 0.07 (very faint)
      - container anchored absolute bottom: 0
      - inner text offset bottom: -186px so it clips beyond the hero
      - z-index -1 under the cards
    The hero's own `overflow-hidden` clips the lower portion, leaving only
    the top half of the wordmark visible behind the card row.
  -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 bottom-0 h-[210px] overflow-hidden -z-0"
  >
    <span
      class="hero-wm absolute left-1/2 -translate-x-1/2 -bottom-[120px] md:-bottom-[186px] select-none whitespace-nowrap leading-none text-white"
      style="font-family: 'Satoshi', ui-sans-serif, system-ui, sans-serif; font-weight: 900; letter-spacing: -0.08em; opacity: 0.07; font-size: clamp(180px, 34vw, 400px);"
    >
      ailb
    </span>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-5 md:px-8 pt-16 md:pt-20 pb-12 md:pb-0 flex flex-col items-center gap-[60px] md:gap-0 md:justify-between md:h-full">

    <!-- Headline block, max-width 820px to fit line 2 at 70px on one line -->
    <div class="flex flex-col items-center gap-5 max-w-[820px]">
      <p class="hero-enter hero-enter-1 text-center text-[14px] font-normal tracking-[0.02em] text-white/85">
        One agent on <span class="text-white font-semibold">WhatsApp</span>
        and web chat — +961 78 720 415.
      </p>

      <!-- Two-line triangle: line 1 small on top, line 2 big on bottom.
           Triangle comes from a 1.6× char-count ratio plus a larger font:
           "A software engineer owns it." is ~27ch vs "AI does the work." ~17ch,
           so the lower line naturally reads wider even at moderate size. -->
      <!-- Uniform 70px across both lines — matches reference font-size.
           "Software engineer" rendered in a muted/accent color so the
           sentence's emphasis sits on "owns it." — the reference uses the
           same technique (one distinguished word/phrase in a softer color
           inside an otherwise-solid headline). -->
      <h1 class="hero-enter hero-enter-2 text-center font-semibold text-[40px] md:text-[70px] leading-[1em] tracking-[-0.02em]">
        Your agent for<br />
        <span style="color: #5e7591;">life in Lebanon</span>.
      </h1>

      <p class="hero-enter hero-enter-3 text-center max-w-[700px] text-[16px] font-normal text-white leading-[25px]">
        One agent that sells your stuff, books your people, and preps
        your paperwork &mdash; on WhatsApp or right here.
      </p>

      <div class="hero-enter hero-enter-3 flex flex-wrap items-center justify-center gap-3">
        <a
          href="https://wa.me/96178720415?text=Hi%20ailb"
          rel="noopener"
          class="inline-flex items-center justify-center gap-2 text-[#0d1b33] hover:opacity-95 transition-opacity"
          style="height: 46px; padding: 0 28px; border-radius: 500px; background-color: #ffffff; font-family: var(--font-body); font-size: 12px; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase;"
        >
          <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path fill="currentColor" d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2Zm0 18.2a8.2 8.2 0 0 1-4.2-1.1l-.3-.2-3 .8.8-2.9-.2-.3A8.2 8.2 0 1 1 12 20.2Zm4.5-6.1c-.2-.1-1.5-.7-1.7-.8-.2-.1-.4-.1-.6.1-.2.2-.6.8-.8 1-.1.2-.3.2-.5.1a6.7 6.7 0 0 1-3.4-3c-.3-.4 0-.5.2-.7l.4-.5c.1-.2.2-.3.3-.5v-.5c0-.1-.6-1.4-.8-1.9-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.5.1-.7.3-.2.3-.9.9-.9 2.2s.9 2.5 1.1 2.7c.1.2 1.8 2.8 4.4 3.9.6.3 1.1.4 1.5.5.6.2 1.2.2 1.6.1.5-.1 1.5-.6 1.7-1.2.2-.6.2-1.1.2-1.2-.1-.1-.2-.2-.4-.2Z"/></svg>
          Chat on WhatsApp
        </a>
        <button
          type="button"
          data-open-chat
          class="cursor-pointer inline-flex items-center justify-center text-white hover:bg-white/10 transition-colors"
          style="height: 46px; padding: 0 28px; border-radius: 500px; border: 1px solid rgba(255, 255, 255, 0.45); background: transparent; font-family: var(--font-body); font-size: 12px; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase;"
        >
          Try the web chat
        </button>
      </div>

      <p class="hero-enter hero-enter-3 text-center text-[12px] text-white/70">
        No forms. No apps. You talk, it works.
      </p>
    </div>

    <!-- CARD ROW WRAPPER: a cream "tray" sits behind the cards, extending
         14px above them. The tray is translated down ~60px on desktop so
         it straddles the hero/body seam — the hero's bottom edge cuts
         through the tray visually, with the cards' bottom half landing on
         the cream page bg below. Hero section removed its overflow-hidden
         to allow this; watermark has its own overflow-hidden wrapper. -->
    <div class="hero-cardswrap relative w-full max-w-[918px] md:translate-y-[74px]">
      <div
        aria-hidden="true"
        class="hero-tray absolute -top-[14px] left-0 right-0 bottom-0 rounded-[25px] bg-white"
      ></div>

      <ul class="hero-cards relative z-10 flex flex-wrap items-stretch justify-center gap-[10px] px-2 pb-2 md:px-3 md:pb-3">
      {cards.map((c, i) => (
        <li class={`card-enter card-enter-${i + 1} flex-1 min-w-[150px] md:min-w-[180px] basis-[calc(50%-5px)] md:basis-[calc(25%-8px)]`}>
          <a
            href={c.href}
            class="group relative block focus-visible:outline focus-visible:outline-2 focus-visible:outline-white/40 rounded-[20px]"
          >
            <!-- Zone 1: solid-color block, only TOP corners rounded, overflow visible -->
            <div
              class="hc-block relative h-[120px] rounded-t-[20px]"
              style={`background-color: ${c.blockBg};`}
            >
              <!-- Subject wrapper: fixed W + aspect-ratio + negative top -->
              <div
                class="hc-sub absolute left-1/2 -translate-x-1/2"
                style={`width: ${c.imgW}px; aspect-ratio: ${c.imgAspect}; top: ${c.imgTopOffset}px;${c.imgClipTop ? " border-radius: 20px 20px 0 0; overflow: hidden;" : ""}`}
              >
                <Image
                  src={c.image}
                  width={c.imgW * 2}
                  alt=""
                  aria-hidden="true"
                  draggable={false}
                  loading="eager"
                  fetchpriority="high"
                  format="webp"
                  quality={70}
                  class="block w-full h-full pointer-events-none"
                  style={`object-fit: ${c.imgFit}; object-position: ${c.imgPos};${c.imgShadow ? ` filter: ${c.imgShadow};` : ""}`}
                />
              </div>
            </div>

            <!-- Zone 2: label area — matches medvi spec: 70px tall, 0 20px padding,
                 16px Red Hat Text 600, letter-spacing -0.02em, line-height 20px,
                 color #242220, arrow 15×13. -->
            <div class="hc-label h-[70px] rounded-b-[20px] bg-white text-[#242220] px-5 flex items-center justify-between gap-2">
              <div class="min-w-0">
                <p class="font-display font-semibold text-[15px] tracking-[-0.02em] leading-[19px] truncate">
                  {c.label}
                </p>
                <p class="text-[11px] leading-[15px] text-[#6f6b66] truncate">
                  {c.tagline}
                </p>
                {c.hint && (
                  <p class="text-[10px] leading-[14px] font-medium text-[#8a857e]">
                    {c.hint}
                  </p>
                )}
              </div>
              <svg width="15" height="13" viewBox="0 0 15 13" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" class="shrink-0" aria-hidden="true"><path d="M1 6.5h12.5M9 1l5 5.5L9 12"/></svg>
            </div>
          </a>
        </li>
      ))}
      </ul>
    </div>
  </div>
</section>

<style is:global>
  /* Phone (≤809.98, medvi tier): the 2x2 card grid becomes medvi's
     stacked list — full-width 85px rows in the white tray, 78px-wide
     colored thumbnail left, label center, arrow right, 10px gaps. */
  @media (max-width: 809.98px) {
    .hero-cards { flex-direction: column; align-items: stretch; }
    .hero-cards > li { flex: none !important; width: 100%; min-width: 0 !important; }
    .hero-cards a {
      display: flex; flex-direction: row; align-items: center;
      height: 85px; padding: 0 15px 0 14px; gap: 0;
    }
    .hero-cards .hc-block {
      width: 78px; height: 85px !important; flex-shrink: 0;
      border-radius: 12px; overflow: hidden;
    }
    /* the pop-out subject treatment is desktop-only — inside the small
       thumbnail the image just fills the block */
    .hero-cards .hc-sub {
      position: absolute; inset: 0 !important;
      width: auto !important; aspect-ratio: auto !important;
      top: 0 !important; left: 0 !important; transform: none !important;
    }
    .hero-cards .hc-sub img { object-fit: contain !important; object-position: center bottom !important; filter: none !important; }
    .hero-cards .hc-label {
      flex: 1; height: auto; background: transparent;
      padding: 0 8px 0 26px; border-radius: 0;
    }
    /* clones exist only for the tablet carousel */
    .hero-cards .hc-clone { display: none !important; }
  }

  /* Tablet (810–1199.98, medvi tier): the card row becomes a full-bleed
     auto-sliding carousel. Measured on medvi: 216×190 cards, 10px gap,
     track of the 4 cards duplicated ×2 drifting left at 20px/s — one
     904px cycle in 45.2s, linear, infinite. No white tray. */
  @media (min-width: 810px) and (max-width: 1199.98px) {
    .hero-tray { display: none; }
    .hero-cardswrap {
      max-width: none;
      width: 100vw;
      margin-left: calc(50% - 50vw);
      /* no overflow clip here — it would behead the pop-out subjects;
         html/body overflow-x:clip already contains the track */
    }
    .hero-cards {
      flex-wrap: nowrap;
      justify-content: flex-start;
      width: max-content;
      padding: 0;
      animation: hero-cards-slide 45.2s linear infinite;
      will-change: transform;
    }
    .hero-cards > li {
      flex: 0 0 216px !important;
      min-width: 0 !important;
    }
    @media (prefers-reduced-motion: reduce) {
      .hero-cards { animation: none; }
    }
  }
  /* pre-shifted one card so a cut card bleeds at the left edge like
     medvi; one 904px set per cycle */
  @keyframes hero-cards-slide {
    from { transform: translateX(-226px); }
    to   { transform: translateX(-1130px); }
  }
  /* desktop: carousel clones stay out of the static 4-card row */
  @media (min-width: 1200px) {
    .hero-cards .hc-clone { display: none !important; }
  }
</style>

<script is:inline>
  // Duplicate the 4 hero cards once so the tablet carousel can loop
  // seamlessly (track slides one full set: 4 x (216 + 10) = 904px).
  // Clones are display:none outside the tablet tier.
  (function () {
    var ul = document.querySelector(".hero-cards");
    if (!ul) return;
    var items = [].slice.call(ul.children);
    // two clone sets (12 cards total): after a full 904px cycle the
    // remaining track must still cover the widest tablet viewport
    for (var set = 0; set < 2; set++) {
      items.forEach(function (li) {
        var c = li.cloneNode(true);
        c.classList.add("hc-clone");
        c.classList.remove("card-enter", "card-enter-1", "card-enter-2", "card-enter-3", "card-enter-4");
        c.setAttribute("aria-hidden", "true");
        ul.appendChild(c);
      });
    }
  })();
</script>
