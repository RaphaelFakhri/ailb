    // Medvi's exact path — dollar sign inside a thin-stroke circle.
    iconBody: `<path d="M0 12A12 12 0 0 1 12 0a12 12 0 0 1 12 12 12 12 0 0 1-12 12A12 12 0 0 1 0 12Zm4.434-7.565A10.63 10.63 0 0 0 1.3 12a10.631 10.631 0 0 0 3.134 7.566A10.629 10.629 0 0 0 12 22.7a10.63 10.63 0 0 0 7.566-3.134A10.631 10.631 0 0 0 22.7 12a10.631 10.631 0 0 0-3.134-7.565A10.631 10.631 0 0 0 12 1.3a10.63 10.63 0 0 0-7.566 3.134Zm7.1 13.5V16.7a6.48 6.48 0 0 1-1.606-.333 5.622 5.622 0 0 1-1.445-.735l.707-1.181a5.632 5.632 0 0 0 1.155.623 5.013 5.013 0 0 0 1.19.31v-2.718l-.854-.221a3.146 3.146 0 0 1-1.559-.872 2.139 2.139 0 0 1-.514-1.471 2.361 2.361 0 0 1 .782-1.856 3.4 3.4 0 0 1 2.145-.77v-1.22h.862V7.5a5.5 5.5 0 0 1 1.447.35 5.621 5.621 0 0 1 1.3.711l-.676 1.159a4.908 4.908 0 0 0-2.067-.89v2.6l.841.222a3.379 3.379 0 0 1 1.625.866 2.054 2.054 0 0 1 .517 1.448 2.574 2.574 0 0 1-.364 1.367 2.581 2.581 0 0 1-1.032.947 4.013 4.013 0 0 1-1.586.421v1.233Zm.862-2.537a1.981 1.981 0 0 0 1.111-.4 1.076 1.076 0 0 0 .4-.864.908.908 0 0 0-.272-.7 2.833 2.833 0 0 0-.992-.49l-.251-.081Zm-1.959-6.253a1.039 1.039 0 0 0-.4.846.934.934 0 0 0 .283.707 2.291 2.291 0 0 0 .945.457l.272.074V8.78a1.83 1.83 0 0 0-1.105.361Z"/>`,
