---
// Trust-badge strip — modeled after the row at the top of medvi.org's
// Footer (~84% through their home page). Spec lifted verbatim from
// medvi's compiled framer CSS:
//   row:   4-col grid (2-col mobile), gap 0, 1px top+bottom border #ddd
//   cell:  100px tall (120px mobile), 0 30px padding, 17px icon→text gap
//   text:  14px / 600 / #242220 (Red Hat Text style)
//   icons: solid-filled glyphs in #38312c, native viewBox kept per icon
//
// ailb mapping — neutral text chips with neutral glyphs:
//   - WhatsApp-first  → person+check (reachable human-style channel)
//   - Claude-powered  → starburst-with-check (quality seal)
//   - Cloudflare edge → lightning bolt (fast at the edge)
//   - Open source     → dollar-in-circle stand-in (free as in open)

type Badge = {
  label: string;
  // Per-icon native viewBox — medvi's truck and stethoscope are non-square,
  // so each icon carries its own width/height to render at intended size.
  iconWidth: number;
  iconHeight: number;
  iconBody: string;
};

const badges: Badge[] = [
  {
    label: "Claude-powered",
