---

<section class="bg-white text-[#242220]" aria-label="Why ailb">
  <ul
    class="blur-up grid grid-cols-2 min-[1200px]:grid-cols-4 border-y border-[#ddd]"
  >
    {badges.map((b, i) => {
      // Per-cell border classes — translation of medvi's per-cell border vars.
      // Desktop >=1200 (4 col): cells 2,3,4 each get left border (3 vertical dividers).
      // Tablet/phone <1200 (2 col, 2 rows): cells 2 & 4 (col 2) get left; cells 3 & 4 (row 2)
      // get top border for the inter-row hairline.
      const isMobileCol2 = i % 2 === 1;       // index 1 or 3
      const isMobileRow2 = i >= 2;             // index 2 or 3
      const isDesktopAfterFirst = i > 0;       // 1, 2, 3
      const cls = [
        "bg-white flex items-center h-[120px] min-[1200px]:h-[100px] px-[30px]",
        // Mobile vertical divider (col 2)
        isMobileCol2 ? "border-l border-[#ddd]" : "",
        // Mobile horizontal divider (row 2 cells)
        isMobileRow2 ? "border-t border-[#ddd]" : "",
        // Desktop overrides: kill mobile row-2 top, ensure all but first have left
        isMobileRow2 ? "min-[1200px]:border-t-0" : "",
        isDesktopAfterFirst ? "min-[1200px]:border-l min-[1200px]:border-[#ddd]" : "",
        // First cell on desktop has no left (override mobile if any)
        !isDesktopAfterFirst ? "min-[1200px]:border-l-0" : "",
      ].filter(Boolean).join(" ");
      return (
      <li
        class={cls}
        style="gap: 17px;"
      >
        <span class="shrink-0 inline-flex" style="color: #38312c;">
          <svg
            width={b.iconWidth}
            height={b.iconHeight}
            viewBox={`0 0 ${b.iconWidth} ${b.iconHeight}`}
            fill="currentColor"
            aria-hidden="true"
            set:html={b.iconBody}
          />
        </span>
        <p class="text-[14px] font-semibold leading-[20px]">
          {b.label}
        </p>
      </li>
      );
    })}
  </ul>
</section>
