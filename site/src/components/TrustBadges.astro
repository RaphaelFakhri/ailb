    iconBody: `<path d="M12 2.4a4.6 4.6 0 1 0 0 9.2 4.6 4.6 0 0 0 0-9.2Zm0 1.3a3.3 3.3 0 1 1 0 6.6 3.3 3.3 0 0 1 0-6.6Z"/><path d="M12 13.1c-4.4 0-8 2.7-8 6v1.6a.6.6 0 0 0 .6.6h11a5.7 5.7 0 0 1-.5-1.3H5.3v-.9c0-2.2 3-4.7 6.7-4.7 1 0 2 .2 2.8.5a5.7 5.7 0 0 1 1.1-.85 9.6 9.6 0 0 0-3.9-.95Z"/><path d="M19 15.4a3.6 3.6 0 1 0 0 7.2 3.6 3.6 0 0 0 0-7.2Zm1.55 2.6-2.05 2.4a.5.5 0 0 1-.74.03l-1.05-1.1a.5.5 0 1 1 .72-.7l.66.7 1.7-1.99a.5.5 0 0 1 .76.66Z"/>`,
