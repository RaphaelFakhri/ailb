    // Solid lightning bolt, fill style consistent with medvi's other glyphs.
    iconBody: `<path d="M14.6 1.5a.6.6 0 0 1 1.07.46L13.6 9.9h6.4a.6.6 0 0 1 .46.99l-12 13.6a.6.6 0 0 1-1.06-.5l2.06-7.99H3a.6.6 0 0 1-.45-1L14.6 1.5Z"/>`,
